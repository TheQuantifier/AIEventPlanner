{
  "name": "ai-event-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "node --env-file=.env api/server.js",
    "dev:web": "node --env-file=.env web/server.js",
    "start": "node api/server.js",
    "start:web": "node web/server.js",
    "check": "node --check api/server.js && node --check web/server.js && node --check web/app.js && node --check scripts/setup-brevo-inbound-webhook.js",
    "setup:brevo-webhook": "node --env-file=.env scripts/setup-brevo-inbound-webhook.js"
  }
}
